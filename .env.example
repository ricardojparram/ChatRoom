# Variables para la base de datos
DB_NAME=chat
DB_USER=chatuser
DB_PASS=chatpass
DB_ROOT_PASS=rootpass
DB_HOST=db

# URL base de la aplicación web
APP_URL=http://localhost:8080/

# Servidor WebSocket (Ratchet)
# IMPORTANTE: SOCKET_IP es la IP donde escucha el servidor WebSocket DENTRO del contenedor
# SOCKET_FRONT es la dirección que el NAVEGADOR usa para conectarse al WebSocket.
# Si accedes desde la misma máquina donde corre Podman, usa localhost:1616.
# Si accedes desde otro dispositivo, cambia esto a la IP/dominio del servidor.
SOCKET_IP=0.0.0.0
SOCKET_PORT=1616
SOCKET_FRONT=localhost:1616
